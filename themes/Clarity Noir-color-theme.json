		"editorGroup.border": "#ff0000",
		"editorGroupHeader.tabsBackground": "#1e1e1e",
		"list.dropBackground": "#027aff80",
		"sideBar.border": "#000000",
		"statusBar.background": "#027aff",
		"statusBar.foreground": "#dcdcdc",
		"statusBarItem.errorBackground": "#ff3b11",
		"statusBarItem.errorForeground": "#dcdcdc",
		"statusBarItem.errorHoverBackground": "#ff5833",
		"statusBarItem.errorHoverForeground": "#dcdcdc",
		"panel.dropBorder": "#027aff",
		"tab.activeBackground": "#1e1e1e",
		"tab.activeForeground": "#dcdcdc",
		"tab.border": "#000000",
		"tab.dragAndDropBorder": "#027aff",
		"tab.hoverBackground": "#ffffff1c",
		"tab.inactiveBackground": "#1e1e1e",
		"tab.inactiveForeground": "#8c8c8c",
		"list.dropBetweenBackground": "#ff0000",
		"terminal.ansiBlack": "#1E1E1E",
		"terminal.ansiBrightBlack": "#525252",
		"terminal.ansiRed": "#FF3B11",
		"terminal.ansiBrightRed": "#FF6947",
		"terminal.ansiGreen": "#2ACD41",
		"terminal.ansiBrightGreen": "#45D968",
		"terminal.ansiYellow": "#FFCC00",
		"terminal.ansiBrightYellow": "#FFD633",
		"terminal.ansiBlue": "#027AFF",
		"terminal.ansiBrightBlue": "#3392FF",
		"terminal.ansiMagenta": "#B051DE",
		"terminal.ansiBrightMagenta": "#C076E5",
		"terminal.ansiCyan": "#02C7BE",
		"terminal.ansiBrightCyan": "#02F2E6",
		"terminal.ansiWhite": "#DCDCDC",
		"terminal.ansiBrightWhite": "#FFFFFF",
		"terminal.foreground": "#DCDCDC",
		"terminal.background": "#1E1E1E",
		"terminalCursor.background": "#DCDCDC"
	},
	"tokenColors": [
		{
			"name": "Assignment Punctuation",
			"scope": "punctuation.eq",
			"settings": {
				"foreground": "#8c8c8c"
			}
		},
		{
			"name": "Boolean Value",
			"scope": "constant.language.boolean",
			"settings": {
				"foreground": "#3392ff",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Character > Escaped",
			"scope": "constant.character.escape",
			"settings": {
				"foreground": "#ffcc00"
			}
		},
		{
			"name": "Colors",
			"scope": "constant.other.color",
			"settings": {
				"foreground": "#e08300"
			}
		},
		{
			"name": "Color Punctuation",
			"scope": "constant.other.color punctuation",
			"settings": {
				"foreground": "#8c8c8c"
			}
		},
		{
			"name": "Comments",
			"scope": "comment",
			"settings": {
				"foreground": "#8c8c8c"
			}
		},
		{
			"name": "Comment Punctuation",
			"scope": "comment punctuation.definition",
			"settings": {
				"foreground": "#686868"
			}
		},
		{
			"name": "Definition Punctuation",
			"scope": "punctuation.definition",
			"settings": {
				"foreground": "#8c8c8c"
			}
		},
		{
			"name": "Functions",
			"scope": [
				"entity.name.function",
				"meta.function"
			],
			"settings": {
				"foreground": "#ffde5c"
			}
		},
		{
			"name": "Keyword",
			"scope": "keyword",
			"settings": {
				"foreground": "#c076e5"
			}
		},
		{
			"name": "Modifier",
			"scope": "storage.modifier",
			"settings": {
				"foreground": "#c076e5"
			}
		},
		{
			"name": "Null",
			"scope": "constant.language.null",
			"settings": {
				"foreground": "#c076e5",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Number",
			"scope": "constant.numeric",
			"settings": {
				"foreground": "#67e077"
			}
		},
		{
			"name": "Operator",
			"scope": "keyword.operator",
			"settings": {
				"foreground": "#8c8c8c"
			}
		},
		{
			"name": "Scope Punctuation",
			"scope": [
				"punctuation.curlybrace",
				"punctuation.section"
			],
			"settings": {
				"foreground": "#8c8c8c"
			}
		},
		{
			"name": "Separators",
			"scope": "punctuation.separator",
			"settings": {
				"foreground": "#686868"
			}
		},
		{
			"name": "Statement Terminators",
			"scope": "punctuation.terminator",
			"settings": {
				"foreground": "#686868"
			}
		},
		{
			"name": "Storage",
			"scope": "storage.type",
			"settings": {
				"foreground": "#c076e5"
			}
		},
		{
			"name": "String",
			"scope": "string",
			"settings": {
				"foreground": "#e08300"
			}
		},
		{
			"name": "String > Punctuation",
			"scope": "string punctuation.definition",
			"settings": {
				"foreground": "#e08300"
			}
		},
		{
			"name": "Types",
			"scope": "entity.name.type",
			"settings": {
				"foreground": "#2acd41"
			}
		},
		{
			"name": "Variables",
			"scope": "variable",
			"settings": {
				"foreground": "#8fbeff"
			}
		},
		{
			"name": "[C#] Interface",
			"scope": "source.cs entity.name.type.interface",
			"settings": {
				"foreground": "#67e077"
			}
		},
		{
			"name": "[CSS] At-Rules",
			"scope": "source.css meta.at-rule keyword.control.at-rule",
			"settings": {
				"foreground": "#c076e5"
			}
		},
		{
			"name": "[CSS] At-Rule Punctuation",
			"scope": "source.css meta.at-rule punctuation",
			"settings": {
				"foreground": "#8c8c8c"
			}
		},
		{
			"name": "[CSS] Constants",
			"scope": "source.css support.constant.property-value",
			"settings": {
				"foreground": "#e0b400"
			}
		},
		{
			"name": "[CSS] Property Names > Not Recognized",
			"scope": [
				"source.css meta.at-rule.media.header",
				"source.css meta.property-name"
			],
			"settings": {
				"foreground": "#8c8c8c"
			}
		},
		{
			"name": "[CSS] Property Names > Recognized",
			"scope": [
				"source.css meta.at-rule.media.header support.type.property-name",
				"source.css meta.property-name support.type.property-name"
			],
			"settings": {
				"foreground": "#dcdcdc"
			}
		},
		{
			"name": "[CSS] Selector > Class",
			"scope": "source.css entity.other.attribute-name.class",
			"settings": {
				"foreground": "#ffcc00"
			}
		},
		{
			"name": "[CSS] Selector > ID",
			"scope": "source.css entity.other.attribute-name.id",
			"settings": {
				"foreground": "#ff2e55"
			}
		},
		{
			"name": "[CSS] Selector > Tag",
			"scope": "source.css entity.name.tag.css",
			"settings": {
				"foreground": "#3392ff"
			}
		},
		{
			"name": "[CSS] Variable Function",
			"scope": "source.css meta.function.variable",
			"settings": {
				"foreground": "#c076e5"
			}
		},
		{
			"name": "[HTML] Attribute Names",
			"scope": "text.html.derivative entity.other.attribute-name",
			"settings": {
				"foreground": "#3392ff",
				"fontStyle": "italic"
			}
		},
		{
			"name": "[HTML] DOCTYPE",
			"scope": [
				"text.html.derivative meta.tag.metadata.doctype entity.name.tag",
				"text.html.derivative meta.tag.metadata.doctype entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#3392ff",
				"fontStyle": "italic"
			}
		},
		{
			"name": "[HTML] Tags",
			"scope": "text.html.derivative entity.name.tag",
			"settings": {
				"foreground": "#02c7be"
			}
		},
