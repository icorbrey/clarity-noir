{
	"name": "Clarity Noir",
	"colors": {
		"activityBar.background": "#282828",
		"activityBar.border": "#000000",
		"activityBar.dropBorder": "#027aff",
		"activityBar.foreground": "#dcdcdc",
		"activityBar.activeBorder": "#dcdcdc",
		"activityBar.inactiveForeground": "#8c8c8c",
