		{
			"name": "Strikethrough Text",
			"scope": "markup.strikethrough",
			"settings": {
				"foreground": "#8c8c8c",
				"fontStyle": "strikethrough"
			}
		},
		{
			"name": "Strings",
			"scope": "string",
			"settings": {
				"foreground": "#e08300"
			}
		},
		{
			"name": "Raw Punctuation",
			"scope": "punctuation.definition.raw",
			"settings": {
				"foreground": "#686868"
			}
		},
		{
			"name": "Raw Text",
			"scope": "markup.inline.raw",
			"settings": {
