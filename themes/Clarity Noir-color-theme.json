			"name": "[HTML] Tag Punctuation",
			"scope": "text.html.derivative punctuation.definition.tag",
			"settings": {
				"foreground": "#8c8c8c"
			}
		},
		{
			"name": "[JSON] Constant Values",
			"scope": "source.json constant.language",
			"settings": {
				"foreground": "#3392ff",
				"fontStyle": "italic"
			}
		},
