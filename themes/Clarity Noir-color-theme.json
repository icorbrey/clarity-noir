    "tokenColors": [
        {
            "name": "Blockquote",
            "scope": "markup.quote",
            "settings": {
                "foreground": "#8c8c8c"
            }
        },
        {
            "name": "Blockquote > Punctuation",
            "scope": "markup.quote punctuation.definition",
            "settings": {
                "foreground": "#686868"
            }
        },
        {
            "name": "Bold",
            "scope": "markup.bold",
            "settings": {
                "foreground": "#02c7be",
