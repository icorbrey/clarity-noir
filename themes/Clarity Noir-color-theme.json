	"tokenColors": [
		{
			"name": "Bold Markers",
			"scope": "punctuation.definition.bold",
			"settings": {
				"fontStyle": "bold",
				"foreground": "#686868"
			}
		},
		{
			"name": "Bold Text",
			"scope": "markup.bold",
			"settings": {
				"fontStyle": "bold",
				"foreground": "#02a29a"
			}
		},
		{
			"name": "Constant Link",
			"scope": "constant.other.reference.link",
			"settings": {
				"foreground": "#ffde5c"
			}
		},
		{
			"name": "Constant Markers",
			"scope": "punctuation.definition.constant",
			"settings": {
				"foreground": "#686868"
			}
		},
		{
			"name": "Heading Markers",
			"scope": "punctuation.definition.heading",
			"settings": {
				"foreground": "#686868"
			}
		},
		{
			"name": "Heading 1",
			"scope": "heading.1 entity.name.section",
			"settings": {
				"foreground": "#ff3b11"
			}
		},
		{
			"name": "Heading 2",
			"scope": "heading.2 entity.name.section",
			"settings": {
				"foreground": "#ff9502"
			}
		},
		{
			"name": "Heading 3",
			"scope": "heading.3 entity.name.section",
			"settings": {
				"foreground": "#ffcc00"
			}
		},
		{
			"name": "Heading 4",
			"scope": "heading.4 entity.name.section",
			"settings": {
				"foreground": "#2acd41"
			}
		},
		{
			"name": "Heading 5",
			"scope": "heading.5 entity.name.section",
			"settings": {
				"foreground": "#027aff"
			}
		},
		{
			"name": "Heading 6",
			"scope": "heading.6 entity.name.section",
			"settings": {
				"foreground": "#b051de"
			}
		},
		{
			"name": "Image Title",
			"scope": "meta.image.inline string.other.link.description",
			"settings": {
				"foreground": "#ff2e55"
			}
		},
		{
			"name": "Italic Markers",
			"scope": "punctuation.definition.italic",
			"settings": {
				"fontStyle": "italic",
				"foreground": "#686868"
			}
		},
		{
			"name": "Italic Text",
			"scope": "markup.italic",
			"settings": {
				"fontStyle": "italic",
				"foreground": "#02f2e6"
			}
		},
		{
			"name": "Link",
			"scope": [
				"meta.image",
				"meta.link"
			],
			"settings": {
				"foreground": "#3392ff"
			}
		},
		{
			"name": "Link Markers",
			"scope": "punctuation.definition.link",
			"settings": {
				"foreground": "#686868"
			}
		},
		{
			"name": "Link Metadata Markers",
			"scope": "punctuation.definition.metadata",
			"settings": {
				"foreground": "#686868"
			}
		},
		{
			"name": "Link Title",
			"scope": "string.other.link.title",
			"settings": {
				"foreground": "#8fbeff"
			}
		},
		{
			"name": "List Markers",
			"scope": "punctuation.definition.list",
			"settings": {
				"foreground": "#8c8c8c"
			}
		},
		{
			"name": "Paragraphs",
			"scope": "meta.paragraph",
			"settings": {
				"foreground": "#dcdcdc"
			}
		},
		{
			"name": "Strikethrough Markers",
			"scope": "punctuation.definition.strikethrough",
			"settings": {
				"foreground": "#686868"
			}
		},
		{
			"name": "Strikethrough Text",
			"scope": "markup.strikethrough",
			"settings": {
				"foreground": "#8c8c8c"
			}
		},
		{
			"name": "Strings",
			"scope": "string",
			"settings": {
				"foreground": "#e08300"
			}
		},
		{
			"name": "Raw Markers",
			"scope": "punctuation.definition.raw",
			"settings": {
				"foreground": "#686868"
			}
		},
		{
			"name": "Raw Text",
			"scope": "markup.inline.raw",
			"settings": {
				"foreground": "#e08300"
			}
		}
	]
}