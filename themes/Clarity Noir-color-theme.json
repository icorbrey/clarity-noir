	"tokenColors": [
		{
			"name": "Blockquote Punctuation",
			"scope": "punctuation.definition.quote",
			"settings": {
				"foreground": "#686868"
			}
		},
		{
			"name": "Blockquote Text",
			"scope": "markup.quote meta.paragraph",
			"settings": {
				"foreground": "#8c8c8c"
			}
		},
		{
			"name": "Bold Punctuation",
			"scope": "punctuation.definition.bold",
			"settings": {
				"fontStyle": "bold",
				"foreground": "#686868"
			}
		},
		{
			"name": "Bold Text",
			"scope": "markup.bold",
			"settings": {
				"fontStyle": "bold",
				"foreground": "#02a29a"
			}
		},
		{
			"name": "Constant Link",
			"scope": "constant.other.reference.link",
			"settings": {
				"foreground": "#ffde5c"
			}
		},
		{
			"name": "Constant Punctuation",
			"scope": "punctuation.definition.constant",
			"settings": {
				"foreground": "#686868"
			}
		},
		{
			"name": "Heading Punctuation",
